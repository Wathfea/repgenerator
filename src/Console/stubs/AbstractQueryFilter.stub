<?php

namespace App\Domain;

use Kblais\QueryFilter\QueryFilter;

class AbstractQueryFilter extends QueryFilter
{
    /**
     * @param  int  $perPage
     */
    public function length(int $perPage)
    {
        $pageNr = $this->request->has('start', 0);
        $this->builder->paginate($perPage, ['*'], 'page', $pageNr);
    }
}
